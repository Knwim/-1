// КЛАСС ЭЛЕМЕНТА БОЛЕЗНИ В СПИСКЕ
/// Компонент для отображения отдельного элемента болезни в динамическом списке
/// Наследуется от MonoBehaviour для прикрепления к префабу заболевания
public class DiseaseItemUI : MonoBehaviour  // Объявляем публичный класс компонента юнити
{
    // Ссылки на UI-элементы, настраиваемые в Inspector префаба
    [SerializeField] private TextMeshProUGUI diseaseNameText;  // Текстовое поле для названия болезни
    [SerializeField] private TextMeshProUGUI symptomsText;  // Текстовое поле для списка симптомов
    [SerializeField] private Image severityImage;  // Изображение-индикатор уровня серьёзности (цвет)
    /// Инициализирует элемент данными конкретной болезни
    /// Вызывается после Instantiation для настройки отображения
    /// <param name="disease">Объект DiseaseData с информацией о болезни</param>
    public void Initialize(DiseaseData disease)  // Публичный метод инициализации с параметром
    {
        // НАСТРОЙКА НАЗВАНИЯ БОЛЕЗНИ 
        // Проверяем наличие текстового поля перед присваиванием
        if (diseaseNameText != null)  // Защита от null-ссылок
            diseaseNameText.text = disease.DiseaseName;  // Устанавливаем текст названия из объекта данных

        // НАСТРОЙКА СПИСКА СИМПТОМОВ
        // Проверяем наличие поля симптомов перед работой с ним
        if (symptomsText != null)  // Проверка на null
        {
            // Объединяем массив строк симптомов в один текст с переносами
            string symptoms = string.Join("\n", disease.Symptoms);  // Метод Join склеивает массив через разделитель
            // Присваиваем сформированный текст текстовому компоненту
            symptomsText.text = symptoms;  // Установка многострочного текста в TextMeshPro
        }

        // НАСТРОЙКА ИНДИКАТОРА СЕРЬЁЗНОСТИ 
        // Проверяем наличие изображения-индикатора
        if (severityImage != null)  // Защита от ошибок при отсутствии компонента
        {
            // ЛОГИКА ЦВЕТОВОГО КОДИРОВАНИЯ 
            // Сравниваем уровень серьёзности с порогами для выбора цвета
            if (disease.Severity > 0.7f)  // Если серьёзность выше 70% - критичный уровень
                severityImage.color = Color.red;  // Красный цвет = опасность, требует срочного внимания
            else if (disease.Severity > 0.4f)  // Если серьёзность от 40% до 70% - средний уровень
                severityImage.color = Color.yellow;  // Жёлтый цвет = предупреждение, стоит наблюдать
            else  // Если серьёзность ниже 40% - низкий уровень
                severityImage.color = Color.green;  // Зелёный цвет = не критично, профилактика
        }
    }
}
