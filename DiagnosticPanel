using UnityEngine;
using TMPro;
using UnityEngine.UI;
using System.Collections.Generic;

/// Класс панели детальной диагностики растения
/// Отвечает за отображение полной информации состояние, болезни, рекомендации по уходу
/// Наследуется от MonoBehaviour для возможности прикрепления к GameObject в сцене
public class DiagnosticPanel : MonoBehaviour  // Объявляю публичный класс наследуемый от MonoBehaviour
{
    // СЕРИАЛИЗУЕМЫЕ ПОЛЯЯЯЯЯ
    // Группируем основные настройки панели в отдельную секцию для удобства в Inspector
    [Header("Panel")]  // Заголовок секции "Панель" в окне Inspector
    [SerializeField] private GameObject panel;              // Ссылка на корневой объект панели (управление видимостью)
    [SerializeField] private Button closeButton;            // Ссылка на кнопку закрытия панели (обработчик клика)

    // Секция для текстовых полей с основной информацией о растении
    [Header("Plant Info")]  // Заголовок "Информация о растении" в Inspector
    [SerializeField] private TextMeshProUGUI plantNameText; // Текстовое поле для отображения названия растения на русском
    [SerializeField] private TextMeshProUGUI latinNameText; // Текстовое поле для латинского названия (ботаническое имя)
    [SerializeField] private TextMeshProUGUI descriptionText; // Текстовое поле с подробным описанием вида растения

    // Секция для визуальных индикаторов условий среды (прогресс-бары)
    [Header("Conditions")]  // Заголовок "Условия среды" в Inspector
    [SerializeField] private ProgressBar lightBar;          // Кастомный класс прогресс-бара для уровня освещённости
    [SerializeField] private ProgressBar windBar;           // Кастомный класс прогресс-бара для скорости ветра
    [SerializeField] private ProgressBar tempBar;           // Кастомный класс прогресс-бара для температуры
    [SerializeField] private ProgressBar healthBar;         // Кастомный класс прогресс-бара для здоровья растения

    // Секция для динамического списка заболеваний
    [Header("Diseases")]  // Заголовок "Заболевания" в Inspector
    [SerializeField] private Transform diseasesList;        // Родительский объект для списка элементов болезней (контейнер)
    [SerializeField] private GameObject diseaseItemPrefab;  // Префаб элемента болезни (шаблон для создания через Instantiate)

    // Секция для текстовых рекомендаций по уходу
    [Header("Recommendations")]  // Заголовок "Рекомендации" в Inspector
    [SerializeField] private TextMeshProUGUI recommendationsText; // Текстовое поле для вывода сгенерированных советов игроку

    // ВНУТРЕННИЕ ПОЛЯ КЛАССА :(
    // Приватная ссылка на данные текущего растения - задаётся извне через метод ShowPlantInfo
    private PlantData currentPlant;  // Хранит объект с параметрами растения для расчётов и отображения

    // МЕТОДЫ ЖИЗНЕННОГО ЦИКЛА ЮНИТИ
    // старт вызывается один раз при активации объекта - используем для первоначальной настройки
    private void Start()  // Объявляем приватный метод инициализации (вызывается автоматически Unity)
    {
        // Скрываем панель при старте сцены - она будет показана только по запросу
        panel.SetActive(false);  // Деактивируем GameObject панели (видимость = false)
        // Настраиваем обработчик нажатия для кнопки закрытия с проверкой на null
        if (closeButton != null)  // Проверяем, назначена ли кнопка в Inspector (защита от ошибок)
            closeButton.onClick.AddListener(ClosePanel);  // Подписываем метод ClosePanel на событие клика
    }

    // ПУБЛИЧНЫЙ МЕТОД ПОКАЗА ИНФОРМАЦИИ
    /// Публичный метод для отображения детальной информации о растении
    /// Вызывается из других скриптов 
    /// <param name="plant">Объект PlantData с данными растения</param>
    public void ShowPlantInfo(PlantData plant)  // Публичный метод принимающий объект данных растения
    {
        // Проверяем входной параметр на null - защита от передачи пустой ссылки
        if (plant == null)  // Если передан null вместо данных растения
        {
            // Выводим предупреждение в консоль для отладки (жёлтый текст в консоли)
            Debug.LogWarning("PlantData is null!");  // Логирование ошибки 
            return;  // Прерываем выполнение метода, чтобы избежать NullReferenceException
        }

        // Сохраняею ссылку на растение в приватное поле класса для использования в других методах
        currentPlant = plant;  // Присваиваем переданный объект внутреннему полю
        // ОБНОВЛЕНИЕ ОСНОВНОЙ ИНФОРМАЦИИ 
        // Устанавливаем текст названия растения в UI-элемент
        plantNameText.text = plant.PlantName;  // Присваиваем строковое значение из объекта данных
                                               // Закомментированные поля - можно раскомментировать при необходимости
                                               // latinNameText.text = plant.LatinName;  // Отображение латинского названия (сейчас отключено)
                                               // descriptionText.text = plant.Description;  // Отображение описания вида (сейчас отключено)

        // ОБНОВЛЕНИЕ ПАРАМЕТРОВ СРЕДЫ 
        // Вызываем метод обновления визуальных индикаторов условий (свет, ветер, температура)
        UpdateConditions();  // Метод читает данные из систем и обновляет прогресс-бары
        // ОТОБРАЖЕНИЕ СПИСКА БОЛЕЗНЕЙ
        // Вызываем метод генерации и показа элементов возможных заболеваний
        ShowDiseases();  // Метод создаёт UI-элементы для каждой болезни из базы данных
        // ГЕНЕРАЦИЯ РЕКОМЕНДАЦИЙ 
        // Вызываем метод формирования текстовых советов по уходу за растением
        GenerateRecommendations();  // Метод анализирует условия и строит строку рекомендаций
        // АКТИВАЦИЯ ПАНЕЛИ
        // Показываем панель диагностики игроку после заполнения всеми данными
        panel.SetActive(true);  // Активируем GameObject, делая панель видимой на экране
    }

    // МЕТОД ОБНОВЛЕНИЯ ИНДИКАТОРОВ УСЛОВИЙ
    /// Обновляет значения и визуальное состояние прогресс-баров условий среды
    private void UpdateConditions()  // Приватный метод, вызывается только внутри класса
    {
        // ОБНОВЛЕНИЕ ОСВЕЩЕНИЯ
        // Проверяем наличие экземпляра системы света и текущего растения (защита от null)
        if (LightSystem.Instance != null && currentPlant != null)  // Условие для безопасного доступа
        {
            // Запрашиваем текущий уровень инсоляции для позиции растения через синглтон
            float currentLight = LightSystem.Instance.GetInsolationForPlant(transform);  // Получаем значение 0.0-1.0
            // Обновляем визуальный прогресс-бар освещения через кастомный класс
            lightBar.SetValue(currentLight);  // Устанавливаем текущее значение на слайдере
            // Настраиваем визуальный диапазон нормы для подсветки оптимальной зоны
            lightBar.SetOptimalRange(currentPlant.MinLight, currentPlant.MaxLight);  // Передаём мин/макс допустимые значения
        }

        // ОБНОВЛЕНИЕ ВЕТРА
        // Проверяем наличие менеджера ветра и данных растения
        if (WindManager.Instance != null && currentPlant != null)  // Защита от null-ссылок
        {
            // Получаем текущую скорость ветра из глобального менеджера погоды
            float currentWind = WindManager.Instance.CurrentWindSpeed;  // Значение в м/с
            // Обновляем прогресс-бар ветра текущим значением
            windBar.SetValue(currentWind);  // Устанавливаем значение на визуальном элементе
            // Устанавливаем максимально допустимое значение ветра для данного вида растения
            windBar.SetMaxValue(currentPlant.WindTolerance);  // Передаём порог устойчивости к ветру
        }

        // ОБНОВЛЕНИЕ ТЕМПЕРАТУРЫ 
        // Временная заглушка - в финальной версии брать данные из WeatherSystem
        tempBar.SetValue(0.7f);  // Хардкод-значение 70% для тестирования визуала (заменить на реальные данные)
        // ОБНОВЛЕНИЕ ЗДОРОВЬЯ
        // Вычисляем интегральный показатель здоровья на основе всех факторов
        float health = CalculateHealth();  // Вызов приватного метода расчёта (возвращает 0.0-1.0)
        // Обновляем визуальный индикатор здоровья рассчитанным значением
        healthBar.SetValue(health);  // Устанавливаем значение на прогресс-баре здоровья
    }

    // МЕТОД ОТОБРАЖЕНИЯ СПИСКА БОЛЕЗНЕЙ
    /// Генерирует и отображает список возможных заболеваний для текущего растения
    private void ShowDiseases()  // Приватный метод работы с динамическим списком
    {
        // ОЧИСТКА СТАРОГО СПИСКА 
        // Проходим по всем дочерним объектам контейнера болезней
        foreach (Transform child in diseasesList)  // Цикл по всем Transform-потомкам
        {
            // Уничтожаем каждый дочерний GameObject для очистки перед новым заполнением
            Destroy(child.gameObject);  // Отложенное удаление объектов через Unity-метод
        }
        // Проверяем наличие данных растения перед продолжением
        if (currentPlant == null) return;  // Если растение не задано - выходим из метода
        // ЗАПРОС ДАННЫХ ИЗ БАЗЫ
        // Получаем экземпляр менеджера базы данных через синглтон-паттерн
        DatabaseManager db = DatabaseManager.Instance;  // Ссылка на глобальный экземпляр БД
        // Проверяем инициализацию базы данных
        if (db == null) return;  // Если БД не загружена - выходим, чтобы избежать ошибок
        // Запрашиваем список болезней, характерных для данного вида растения
        List<DiseaseData> diseases = db.GetDiseasesForPlant(currentPlant);  // Возвращает список объектов данных
        // ОБРАБОТКА РЕЗУЛЬТАТОВ ЗАПРОСА 
        // Проверяем, найдены ли болезни для текущего растения
        if (diseases.Count == 0)  // Если список пустой - болезней не обнаружено
        {
            // Создаём текстовый элемент "нет болезней" из префаба
            TextMeshProUGUI noDiseasesText = Instantiate(diseaseItemPrefab, diseasesList)  // Спавним объект в контейнер
                .GetComponent<TextMeshProUGUI>();  // Получаем текстовый компонент для настройки
            // Устанавливаем текст сообщения об отсутствии заболеваний
            noDiseasesText.text = "Заболеваний не обнаружено ✓";  // Позитивное сообщение с галочкой
            // Красим текст в зелёный цвет для визуального подтверждения
            noDiseasesText.color = Color.green;  // Установка цвета через Unity Color
        }
        else  // Если болезни найдены - создаём элементы для каждой
        {
            // Проходим по каждому объекту болезни в полученном списке
            foreach (DiseaseData disease in diseases)  // Цикл по коллекции DiseaseData
            {
                // Создаём экземпляр UI-элемента болезни в контейнере списка
                GameObject diseaseItem = Instantiate(diseaseItemPrefab, diseasesList);  // Instantiation префаба
                // Получаем скрипт управления элементом болезни для инициализации
                DiseaseItemUI diseaseUI = diseaseItem.GetComponent<DiseaseItemUI>();  // Запрос компонента на объекте
                // Проверяем успешное получение компонента перед использованием
                if (diseaseUI != null)  // Если компонент найден на префабе
                {
                    // Инициализируем элемент данными конкретной болезни
                    diseaseUI.Initialize(disease);  // Передаём объект DiseaseData для настройки отображения
                }
            }
        }
    }

    // МЕТОД ГЕНЕРАЦИИ ТЕКСТОВЫХ РЕКОМЕНДАЦИЙ
    /// Формирует строку рекомендаций по уходу на основе текущих условий
    private void GenerateRecommendations()  // Приватный метод построения текста советов
    {
        // Проверяем наличие данных растения перед генерацией
        if (currentPlant == null) return;  // Если растение не задано - выходим из метода
        // Создаём StringBuilder для эффективной работы со строками (лучше конкатенации)
        System.Text.StringBuilder sb = new System.Text.StringBuilder();  // Буфер для построения текста
        // Добавляем заголовок раздела рекомендаций с переносом строки
        sb.AppendLine("Рекомендации:");  // Метод добавляет текст и символ новой строки
        // Добавляем пустую строку для визуального отступа после заголовка
        sb.AppendLine();  // Пустая строка для улучшения читаемости
        // ПРОВЕРКА ОСВЕЩЕНИЯ 
        // Проверяем доступность системы освещения для получения данных
        if (LightSystem.Instance != null)  // Если синглтон инициализирован
        {
            // Запрашиваем текущий уровень освещённости для позиции растения
            float light = LightSystem.Instance.GetInsolationForPlant(transform);  // Значение 0.0-1.0
            // Сравниваем текущий свет с минимально допустимым для вида
            if (light < currentPlant.MinLight)  // Если света недостаточно
            {
                // Добавляем совет переместить растение в более светлое место
                sb.AppendLine("• Переместите растение в более освещённое место");  // Маркированный список
            }
            // Сравниваем текущий свет с максимально допустимым для вида
            else if (light > currentPlant.MaxLight)  // Если света слишком много
            {
                // Добавляем совет убрать растение от прямых солнечных лучей
                sb.AppendLine("• Уберите растение из прямых солнечных лучей");  // Предупреждение о переизбытке
            }
        }

        // ПРОВЕРКА ВЕТРА
        // Проверяем доступность менеджера ветра для получения данных
        if (WindManager.Instance != null)  // Если система ветра работает
        {
            // Получаем текущую скорость ветра из глобального менеджера
            float wind = WindManager.Instance.CurrentWindSpeed;  // Значение в м/с
            // Сравниваем текущий ветер с порогом устойчивости растения
            if (wind > currentPlant.WindTolerance)  // Если ветер слишком сильный
            {
                // Добавляем непрошеный совет защитить растение от ветровой нагрузки
                sb.AppendLine("• Защитите растение от сильного ветра");  // Рекомендация по защите
            }
        }
        // ОБЩИЕ СОВЕТЫ ПО УХОДУ 
        // Добавляем универсальный совет по контролю влажности почвы
        sb.AppendLine("• Регулярно проверяйте влажность почвы");  // Базовая рекомендация для всех растений
        // Добавляем совет по визуальному мониторингу состояния листьев
        sb.AppendLine("• Осматривайте листья на наличие болезней");  // Профилактическая рекомендация
        // Присваиваем сформированный текст текстовому полю UI
        recommendationsText.text = sb.ToString();  // Конвертируем StringBuilder в строку и устанавливаем в TextMeshPro
    }

    // МЕТОД РАСЧЁТА ИНТЕГРАЛЬНОГО ЗДОРОВЬЯ
    /// Рассчитывает общий показатель здоровья растения на основе факторов среды
    /// <returns>Значение от 0.0 (критично) до 1.0 (идеально)</returns>
    private float CalculateHealth()  // Приватный метод, возвращающий float-значение
    {
        // Проверяем наличие данных растения перед расчётами
        if (currentPlant == null) return 0f;  // Если растение не задано - возвращаем минимальное здоровье
        // ПОЛУЧЕНИЕ ФАКТОРА ОСВЕЩЕНИЯ 
        // Используем тернарный оператор для безопасного получения значения
        float light = LightSystem.Instance != null ?  // Проверка: если система света существует
            LightSystem.Instance.GetInsolationForPlant(transform) : 0.5f;  // Берём реальное значение или дефолт 0.5

        // ПОЛУЧЕНИЕ ФАКТОРА ВЕТРА 
        // Аналогичная проверка для менеджера ветра с дефолтным значением
        float wind = WindManager.Instance != null ?  // Проверка: если менеджер ветра инициализирован
            WindManager.Instance.CurrentWindSpeed : 0f;  // Берём скорость ветра или 0 при ошибке

        // ВЫЧИСЛЕНИЕ И ВОЗВРАТ РЕЗУЛЬТАТА 
        // Вызываем метод расчёта из объекта PlantData, передавая все факторы
        return currentPlant.CalculateHealthFactor(light, wind, 20f);  // 20f - заглушка температуры, вернуть реальные данные
    }

    // МЕТОДЫ УПРАВЛЕНИЯ ВИДИМОСТЬЮ ПАНЕЛИ
    /// Публичный метод закрытия панели диагностики
    /// Вызывается кнопкой закрытия или из других скриптов
    public void ClosePanel()  // Публичный метод без параметров для UnityEvents
    {
        // Скрываем панель, деактивируя её GameObject
        panel.SetActive(false);  // Установка active = false скрывает объект и все дочерние элементы
        // Очищаем ссылку на текущее растение для сброса состояния
        currentPlant = null;  // Обнуление ссылки для предотвращения устаревших данных при следующем открытии
    }

    /// Публичный метод открытия панели (без загрузки данных)
    public void OpenPanel()  // Публичный метод для внешнего вызова
    {
        // Показываем панель, активируя её GameObject
        panel.SetActive(true);  // Установка active = true делает панель видимой на экране
    }
}

// СЕРИАЛИЗУЕМЫЙ КЛАСС ПРОГРЕСС-БАРА
/// Вспомогательный класс для инкапсуляции логики прогресс-бара
/// [Serializable] позволяет отображать этот класс как складной объект в Inspector
[System.Serializable]  // Атрибут для сериализации класса (отображение в Unity Inspector)
public class ProgressBar  // Объявляем публичный класс (не MonoBehaviour, а обычный C# класс)
{
    // Поля класса, настраиваемые через Inspector благодаря [SerializeField]
    [SerializeField] private Slider slider;  // Ссылка на компонент Slider юнити для визуализации значения
    [SerializeField] private TextMeshProUGUI valueText;  // Ссылка на текстовое поле для отображения числа/процентов
    [SerializeField] private Image fillImage;  // Ссылка на изображение заливки (для изменения цвета/градиента)

    /// Устанавливает текущее значение прогресс-бара и обновляет текст
    /// <param name="value">Значение от 0.0 до 1.0 (или до maxValue)</param>
    public void SetValue(float value)  // Публичный метод установки значения
    {
        // Проверяем наличие слайдера перед изменением его свойства
        if (slider != null)  // Защита от NullReferenceException
            slider.value = value;  // Присваиваем значение компоненту Slider (автоматически обновляет визуал)
        // Проверяем наличие текстового поля для обновления отображения числа
        if (valueText != null)  // Проверка на null перед использованием
            valueText.text = $"{value:P0}";  // Форматируем как проценты без знаков после запятой (0.75 → "75%")
    }

    /// Устанавливает максимальное значение для слайдера
    /// <param name="maxValue">Верхняя граница диапазона</param>
    public void SetMaxValue(float maxValue)  // Публичный метод настройки максимума
    {
        // Проверяем наличие слайдера перед изменением его конфигурации
        if (slider != null)  // Защита от ошибок при отсутствии ссылки
