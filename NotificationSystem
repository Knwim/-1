using UnityEngine;
using TMPro;
using UnityEngine.UI;
using System.Collections;

// Объявляяю публичный класс NotificationSystem, наследуемый от MonoBehaviour - чтобы скрипт можно было повесить на GameObject в сцене
public class NotificationSystem : MonoBehaviour
{
    // Атрибут Header для группировки полей в Inspector - улучшает читаемость при настройке в редакторе
    [Header("Settings")]  // Создаём заголовок "Settings" в окне Inspector для визуального разделения секций
    [SerializeField] private Transform notificationParent;      // Ссылка на родительский Transform для уведомлений - определяет, куда будут спавниться объекты
    [SerializeField] private GameObject notificationPrefab;     // Ссылка на префаб уведомления - шаблон для создания через Instantiate
    [SerializeField] private float displayDuration = 3f;        // Время отображения уведомления в секундах до начала исчезновения (по умолчанию 3 секунды)
    [SerializeField] private float fadeDuration = 0.5f;         // Время плавного исчезновения уведомления в секундах (по умолчанию полсекунды)

    // Секция для настройки цветов разных типов уведомлений
    [Header("Colors by Type")]  // Заголовок "Colors by Type" в Inspector
    [SerializeField] private Color infoColor = Color.blue;      // Цвет для информационных уведомлений - по умолчанию синий
    [SerializeField] private Color successColor = Color.green;  // Цвет для уведомлений об успехе - по умолчанию зелёный
    [SerializeField] private Color warningColor = Color.yellow; // Цвет для предупреждений - по умолчанию жёлтый
    [SerializeField] private Color errorColor = Color.red;      // Цвет для ошибок - по умолчанию красный

    // Публичное статическое свойство для доступа к экземпляру из любого места кода - реализация паттерна Singleton
    public static NotificationSystem Instance { get; private set; }  // Геттер публичный (чтение из любого места), сеттер приватный (запись только внутри класса)
    // ИНИЦИАЛИЗАЦИЯ
    // Awake() вызывается раньше Start() - используем для инициализации синглтона до начала работы других скриптов
    private void Awake()  // Объявляем приватный метод инициализации (вызывается автоматически при загрузке сцены)
    {
        // === РЕАЛИЗАЦИЯ SINGLETON ===
        // Проверяем, существует ли уже экземпляр системы уведомлений - защита от дублирования
        if (Instance == null)  // Если глобальная ссылка ещё не установлена
        {
            // Назначаем текущий объект как единственный экземпляр
            Instance = this;  // Записываем ссылку на этот объект в статическое свойство
        }
        else  // Если экземпляр уже существует (значит этот - дубликат)
        {
            // Уничтожаем дублирующий объект, чтобы не было двух систем уведомлений
            Destroy(gameObject);  // Удаляем текущий GameObject из сцены
        }
    }
    // ПУБЛИЧНЫЕ МЕТОДЫ-ОБЁРТКИ

    // Публичный метод показа информационного уведомления - удобная обёртка для вызова с типом Info
    public void ShowInfo(string message)  // Объявляем публичный метод с параметром текста сообщения
    {
        // Вызываем общий метод показа уведомления, передавая тип Info
        ShowNotification(message, NotificationType.Info);  // Делегирование логики в основной метод
    }
    // Публичный метод показа уведомления об успехе - обёртка для типа Success
    public void ShowSuccess(string message)  // Объявляем публичный метод
    {
        // Вызываем общий метод с типом Success
        ShowNotification(message, NotificationType.Success);  // Делегирование с другим типом
    }
    // Публичный метод показа предупреждения - обёртка для типа Warning
    public void ShowWarning(string message)  // Объявляем публичный метод
    {
        // Вызываем общий метод с типом Warning
        ShowNotification(message, NotificationType.Warning);  // Делегирование с типом предупреждения
    }

    // Публичный метод показа уведомления об ошибке - обёртка для типа Error
    public void ShowError(string message)  // Объявляем публичный метод
    {
        // Вызываем общий метод с типом Error
        ShowNotification(message, NotificationType.Error);  // Делегирование с типом ошибки
    }

    // ВНУТРЕННИЕ МЕТОДЫ
    // Приватный метод создания и отображения уведомления - основная логика системы
    private void ShowNotification(string message, NotificationType type)  // Объявляем приватный метод с параметрами текста и типа
    {
        // Проверяем наличие префаба - без него нельзя создать уведомление
        if (notificationPrefab == null)  // Если префаб не назначен в Inspector
        {
            // Выводим сообщение в консоль как фолбэк-вариант отладки
            Debug.Log($"[{type}] {message}");  // Логирование в формате "[Тип] Сообщение"
            // Прерываем выполнение метода, так как создать уведомление невозможно
            return;  // Выход из метода без создания объекта
        }
        // Проверяем наличие родителя для иерархии
        if (notificationParent == null)  // Если родитель не назначен
        {
            // Используем трансформ этого объекта как родителя по умолчанию
            notificationParent = transform;  // Присваиваю текущий transform как запасной вариант
        }

        // Создаём экземпляр уведомления в иерархии под указанным родителем
        GameObject notification = Instantiate(notificationPrefab, notificationParent);  // Instantiation префаба с позиционированием
        // Получаем скрипт управления уведомлением для инициализации
        NotificationUI notificationScript = notification.GetComponent<NotificationUI>();  // Запрос компонента на созданном объекте
        // Проверяем успешное получение компонента перед использованием
        if (notificationScript != null)  // Если компонент найден на префабе
        {
            // Получаем цвет для текущего типа уведомления через вспомогательный метод
            Color color = GetColorByType(type);  // Вызов метода выбора цвета по типу
            // Инициализируем уведомление текстом и цветом
            notificationScript.Initialize(message, color);  // Передаём данные для настройки UI
            // Запускаем корутину автоматического удаления уведомления через заданное время
            StartCoroutine(AutoDestroyNotification(notification));  // Асинхронное выполнение с параметром объекта
        }
    }

    // Приватный метод получения цвета по типу уведомления - инкапсуляция логики выбора цвета
    private Color GetColorByType(NotificationType type)  // Объявляем приватный метод с возвратом Color
    {
        // Используем switch для выбора цвета в зависимости от типа - читаемая альтернатива if-else
        switch (type)  // Переменная для сравнения с вариантами case
        {
            // Случай информационного уведомления
            case NotificationType.Info:  // Если тип равен Info
                return infoColor;  // Возвращаем настроенный синий цвет
            // Случай уведомления об успехе
            case NotificationType.Success:  // Если тип равен Success
                return successColor;  // Возвращаем настроенный зелёный цвет
            // Случай предупреждения
            case NotificationType.Warning:  // Если тип равен Warning
                return warningColor;  // Возвращаем настроенный жёлтый цвет
            // Случай ошибки
            case NotificationType.Error:  // Если тип равен Error
                return errorColor;  // Возвращаем настроенный красный цвет
            // Дефолтный случай для неизвестных типов
            default:  // Если тип не совпал ни с одним из перечисленных
                return Color.white;  // Возвращаем белый цвет как безопасный дефолт
        }
    }

    // Приватная корутина для автоматического удаления уведомления с плавным исчезновением
    private IEnumerator AutoDestroyNotification(GameObject notification)  // Объявляем корутину с параметром GameObject
    {
        // Ждём заданное время отображения перед началом исчезновения
        yield return new WaitForSeconds(displayDuration);  // Приостановка корутины на displayDuration секунд

        // Получаем компонент управления анимацией уведомления
        NotificationUI notificationUI = notification.GetComponent<NotificationUI>();  // Запрос компонента для анимации
        // Проверяем наличие компонента перед запуском анимации
        if (notificationUI != null)  // Если компонент найден
        {
            // Запускаем корутину плавного исчезновения и ждём её завершения
            yield return StartCoroutine(notificationUI.FadeOut(fadeDuration));  // Ожидание завершения анимации
        }

        // Уничтожаем объект уведомления после завершения анимации
        Destroy(notification);  // Освобождение памяти и удаление из иерархии
    }
}
// КОМПОНЕНТ ОДНОГО УВЕДОМЛЕНИЯ

// Объявляем публичный класс NotificationUI, наследуемый от MonoBehaviour - для прикрепления к префабу уведомления
public class NotificationUI : MonoBehaviour
{
    // Группируем UI-компоненты в отдельную секцию для удобства в Inspector
    [Header("UI Components")]  // Заголовок "UI Components" в Inspector префаба
    [SerializeField] private TextMeshProUGUI messageText;  // Ссылка на текстовое поле для отображения сообщения уведомления
    [SerializeField] private Image backgroundImage;  // Ссылка на фоновое изображение - меняем цвет для визуальной дифференциации типов
    [SerializeField] private CanvasGroup canvasGroup;  // Ссылка на CanvasGroup - нужен для плавного изменения прозрачности (alpha)

    // Приватное поле для кэширования RectTransform - используем часто, поэтому кэшируем в Awake
    private RectTransform rectTransform;  // Ссылка на компонент RectTransform для работы с позицией и размером

    // Awake() вызывается при инициализации объекта - используем для кэширования компонентов
    private void Awake()  // Объявляем приватный метод инициализации
    {
        // Получаем и кэшируем RectTransform компонент этого GameObject
        rectTransform = GetComponent<RectTransform>();  // Запрос компонента для последующего использования
        // Проверяем, назначен ли CanvasGroup в Inspector
        if (canvasGroup == null)  // Если ссылка пустая
        {
            // Пытаемся получить компонент автоматически с этого же GameObject
            canvasGroup = GetComponent<CanvasGroup>();  // Автопоиск компонента на объекте
        }
    }

    // Публичный метод инициализации уведомления - вызывается после Instantiate для настройки
    public void Initialize(string message, Color color)  // Объявляем публичный метод с параметрами текста и цвета
    {
        // Проверяем наличие текстового поля перед присваиванием
        if (messageText != null)  // Если ссылка на текст назначена
        {
            // Устанавливаем текст сообщения в UI-элемент
            messageText.text = message;  // Присваивание строки текстовому компоненту
        }
        // Проверяем наличие фонового изображения
        if (backgroundImage != null)  // Если ссылка на Image назначена
        {
            // Устанавливаем цвет фона согласно переданному параметру
            backgroundImage.color = color;  // Изменение цвета для визуального обозначения типа уведомления
        }
        // Проверяем наличие CanvasGroup для анимаций
        if (canvasGroup != null)  // Если компонент для анимаций найден
        {
            // Устанавливаем полную непрозрачность для начала анимации появления
            canvasGroup.alpha = 1f;  // Alpha = 1 означает полностью видимый объект
            // Разрешаем взаимодействие с элементом (хотя для уведомлений это обычно не нужно)
            canvasGroup.interactable = true;  // Включение интерактивности
            // Запрещаем блокировку рейкастов - уведомление не должно мешать кликам по интерфейсу
            canvasGroup.blocksRaycasts = false;  // Клик проходит сквозь уведомление
        }

        // Запускаем корутину плавного появления уведомления
        StartCoroutine(FadeIn(0.3f));  // Асинхронное выполнение анимации появления за 0.3 секунды
    }

    // Приватная корутина для плавного появления уведомления
    private System.Collections.IEnumerator FadeIn(float duration)  // Объявляем корутину с параметром длительности
    {
        // Проверяем наличие CanvasGroup - без него анимация невозможна
        if (canvasGroup == null) yield break;  // Если компонента нет - прерываем корутину без выполнения
        // Переменная для отслеживания прошедшего времени в секундах
        float elapsed = 0f;  // Инициализация счётчика времени с нуля
        // Цикл выполняется каждый кадр пока не пройдёт заданная длительность анимации
        while (elapsed < duration)  // Условие продолжения: прошло меньше чем duration секунд
        {
            // Плавно изменяем прозрачность от 0 до 1 через линейную интерполяцию
            canvasGroup.alpha = Mathf.Lerp(0f, 1f, elapsed / duration);  // Lerp(a,b,t) где t растёт от 0 к 1
            // Увеличиваем счётчик прошедшего времени на длительность последнего кадра
            elapsed += Time.deltaTime;  // deltaTime - время в секундах с последнего фрейма
            // Приостанавливаем корутину до следующего кадра - ключевая особенность корутин
            yield return null;  // Возврат управления движку, продолжение на следующем кадре
        }

        // После завершения цикла гарантированно устанавливаем финальное значение прозрачности
        canvasGroup.alpha = 1f;  // Фиксация полной видимости для избежания погрешностей вычислений
    }

    // Публичная корутина для плавного исчезновения уведомления - вызывается из NotificationSystem
    public System.Collections.IEnumerator FadeOut(float duration)  // Объявляем публичную корутину
    {
        // Проверяем наличие CanvasGroup перед анимацией
        if (canvasGroup == null) yield break;  // Если компонента нет - прерываем корутину
        // Переменная для отслеживания прошедшего времени
        float elapsed = 0f;  // Инициализация счётчика
        // Сохраняем текущее значение прозрачности как стартовую точку для плавного перехода
        float startAlpha = canvasGroup.alpha;  // Запоминание начального значения alpha
        // Цикл выполняется каждый кадр пока не пройдёт время анимации
        while (elapsed < duration)  // Условие: ещё не прошло достаточно времени
        {
            // Плавно изменяем прозрачность от стартового значения до 0 через линейную интерполяцию
            canvasGroup.alpha = Mathf.Lerp(startAlpha, 0f, elapsed / duration);  // t растёт от 0 к 1, alpha уменьшается
            // Увеличиваем счётчик прошедшего времени
            elapsed += Time.deltaTime;  // Накопление времени
            // Приостанавливаем корутину до следующего кадра
            yield return null;  // Возврат управления, продолжение на следующем фрейме
        }

        // После завершения цикла гарантированно устанавливаем полную прозрачность
        canvasGroup.alpha = 0f;  // Фиксация невидимости для чистоты состояния
    }
}

// ПЕРЕЧИСЛЕНИЕ ТИПОВ УВЕДОМЛЕНИЙ

// Объявляем публичный enum для типизации уведомлений - позволяет выбирать тип при вызове методов
public enum NotificationType  // Перечисление типов для цветовой и логической дифференциации
{
    Info,       // Информационное уведомление (синий цвет) - для обычных сообщений игроку
    Success,    // Успешное действие (зелёный цвет) - для подтверждения выполненных действий
    Warning,    // Предупреждение (жёлтый цвет) - для важных предупреждений, требующих внимания
    Error       // Критическая ошибка (красный цвет) - для сообщений об ошибках и проблемах
}
