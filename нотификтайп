
/// Типы уведомлений для системы сообщений.
/// Определяет категорию уведомления для визуального оформления.
public enum NotificationType
{
    Info,       // Информация (синий цвет)
    Success,    // Успех (зелёный цвет)
    Warning,    // Предупреждение (жёлтый цвет)
    Error       // Ошибка (красный цвет)
}
